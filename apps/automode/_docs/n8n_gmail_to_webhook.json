{
  "name": "Gmail → Webhook 허브",
  "nodes": [
    {
      "parameters": {
        "pollTimes": {
          "item": [{ "mode": "everyMinute" }]
        },
        "filters": {}
      },
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1,
      "position": [0, 304],
      "id": "b1c2d3e4-0001-0001-0001-000000000001",
      "name": "Gmail Trigger",
      "credentials": {
        "gmailOAuth2": {
          "id": "YOUR_GMAIL_CREDENTIAL_ID",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:5678/webhook/paik-orchestrator",
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "subject",
              "value": "={{ $json.Subject || '(제목 없음)' }}"
            },
            {
              "name": "body",
              "value": "={{ $json.snippet || '(내용 없음)' }}"
            },
            {
              "name": "from",
              "value": "={{ $json.From || '(발신자 없음)' }}"
            },
            {
              "name": "source",
              "value": "gmail"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [240, 304],
      "id": "b1c2d3e4-0003-0003-0003-000000000003",
      "name": "Webhook 허브 호출"
    }
  ],
  "pinData": {},
  "connections": {
    "Gmail Trigger": {
      "main": [
        [{ "node": "Webhook 허브 호출", "type": "main", "index": 0 }]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  }
}
